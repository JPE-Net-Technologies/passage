{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "bun run gen:api && next build",
    "dev": "next dev",
    "gen:api": "bun run scripts/gen-api.ts",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "fumadocs-core": "16.10.4",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.4",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "fumadocs-typescript": "^5.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3"
  }
