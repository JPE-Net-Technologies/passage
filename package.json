{
  "name": "passage",
  "version": "1.0.0",
  "description": "Composable, config-driven OAuth2/OIDC identity broker — distributed as @passage/core plus runnable presets.",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter '@passage/core' build",
    "test": "cross-env ENABLE_TEST_LOGS=true bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "cross-env ENABLE_TEST_LOGS=true bun test --coverage",
    "preset:dev": "cross-env NODE_ENV=development bun run --cwd examples/keycloak-basic dev",
    "docs:start": "docusaurus start",
    "docs:build": "docusaurus build",
    "docs:serve": "docusaurus serve",
    "docs:clear": "docusaurus clear"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@types/bun": "^1.2.19",
    "@types/node": "^24.1.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.5.3"
  }
}
