{
  "name": "@passage/core",
  "version": "1.0.0",
  "description": "Composable, config-driven OAuth2/OIDC identity broker core. Inject config, mount the app.",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config-loader.d.ts",
      "bun": "./src/config-loader.ts",
      "default": "./dist/config-loader.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "openid-client": "^6.8.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/supertest": "^6.0.2",
    "supertest": "^6.3.4"
  }
}
